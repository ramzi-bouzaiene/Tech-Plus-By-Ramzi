---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#2563eb">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>📰</text></svg>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <slot />
  <script>
    // Register service worker
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/sw.js');
    }

    // Apply saved theme
    const savedTheme = localStorage.getItem('theme') || 'light';
    document.documentElement.setAttribute('data-theme', savedTheme);
  </script>
</body>
</html>

<style is:global>
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

:root {
  --bg: #fafafa;
  --surface: #ffffff;
  --text: #1a1a1a;
  --text-muted: #666;
  --border: #e5e5e5;
  --accent: #2563eb;
  --ai: #8b5cf6;
  --devtools: #059669;
  --webdev: #f59e0b;
  --industry: #dc2626;
  --tips: #0891b2;
  --shadow: rgba(0,0,0,0.08);
  --trending: #ff6b35;
}

[data-theme="dark"] {
  --bg: #0f0f0f;
  --surface: #1a1a1a;
  --text: #f5f5f5;
  --text-muted: #a0a0a0;
  --border: #2a2a2a;
  --shadow: rgba(0,0,0,0.3);
}

[data-theme="dark"] .category.ai {
  background: #2e1065;
}

[data-theme="dark"] .category.developer-tools {
  background: #064e3b;
}

[data-theme="dark"] .category.web-development {
  background: #78350f;
}

[data-theme="dark"] .category.tech-industry {
  background: #450a0a;
}

[data-theme="dark"] .category.tips-and-tricks {
  background: #164e63;
}

body {
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  background: var(--bg);
  color: var(--text);
  line-height: 1.6;
  min-height: 100vh;
}

.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 1.5rem;
}

/* Header */
header {
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  padding: 2rem 0;
}

.header-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

header h1 {
  font-size: 2rem;
  font-weight: 700;
  letter-spacing: -0.02em;
}

.tagline {
  color: var(--text-muted);
  font-size: 0.95rem;
  margin-top: 0.25rem;
}

.theme-toggle {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 50%;
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: var(--text);
  transition: all 0.2s;
}

.theme-toggle:hover {
  border-color: var(--accent);
  color: var(--accent);
}

.icon-moon { display: none; }
[data-theme="dark"] .icon-sun { display: none; }
[data-theme="dark"] .icon-moon { display: block; }

/* Search */
.search-bar {
  position: relative;
  margin-bottom: 0.5rem;
  margin-top: 1rem;
}

.search-icon {
  position: absolute;
  left: 1rem;
  top: 50%;
  transform: translateY(-50%);
  color: var(--text-muted);
  pointer-events: none;
}

#searchInput {
  width: 100%;
  padding: 0.875rem 1rem 0.875rem 3rem;
  font-size: 1rem;
  font-family: inherit;
  border: 1px solid var(--border);
  border-radius: 12px;
  background: var(--surface);
  color: var(--text);
  transition: all 0.2s;
}

#searchInput::placeholder {
  color: var(--text-muted);
}

#searchInput:focus {
  outline: none;
  border-color: var(--accent);
  box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
}

/* Meta bar */
.meta-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.5rem 0;
  flex-wrap: wrap;
  gap: 1rem;
}

.last-updated {
  color: var(--text-muted);
  font-size: 0.875rem;
}

.filters {
  display: flex;
  gap: 0.5rem;
}

.filter-btn {
  background: var(--surface);
  border: 1px solid var(--border);
  padding: 0.5rem 1rem;
  border-radius: 2rem;
  font-size: 0.875rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
  color: var(--text);
}

.filter-btn:hover {
  border-color: var(--accent);
  color: var(--accent);
}

.filter-btn.active {
  background: var(--text);
  color: var(--bg);
  border-color: var(--text);
}

/* News grid */
.news-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  gap: 1.5rem;
  padding-bottom: 3rem;
}

.news-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 1.5rem;
  transition: box-shadow 0.2s, transform 0.2s;
}

.news-card:hover {
  box-shadow: 0 4px 20px var(--shadow);
  transform: translateY(-2px);
}

.category {
  display: inline-block;
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  padding: 0.25rem 0.75rem;
  border-radius: 1rem;
  margin-bottom: 0.75rem;
}

.category.ai {
  background: #ede9fe;
  color: var(--ai);
}

.category.developer-tools {
  background: #d1fae5;
  color: var(--devtools);
}

.category.tech-industry {
  background: #fee2e2;
  color: var(--industry);
}

.category.web-development {
  background: #fef3c7;
  color: var(--webdev);
}

.category.tips-and-tricks {
  background: #cffafe;
  color: var(--tips);
}

/* Card header with badges and bookmark */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 0.75rem;
}

.card-badges {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.trending-badge {
  font-size: 0.75rem;
  font-weight: 600;
  padding: 0.25rem 0.75rem;
  border-radius: 1rem;
  background: linear-gradient(135deg, #ff6b35, #f72585);
  color: white;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.8; }
}

.news-card.trending {
  border-color: var(--trending);
  box-shadow: 0 0 0 1px var(--trending);
}

/* Bookmark button */
.bookmark-btn {
  background: none;
  border: none;
  padding: 0.5rem;
  cursor: pointer;
  color: var(--text-muted);
  transition: all 0.2s;
  border-radius: 50%;
}

.bookmark-btn:hover {
  background: var(--bg);
  color: var(--accent);
}

.bookmark-btn.bookmarked {
  color: var(--accent);
}

.bookmark-filter svg {
  vertical-align: middle;
  margin-right: 0.25rem;
}

/* Card footer */
.card-footer {
  border-top: 1px solid var(--border);
  padding-top: 0.75rem;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.meta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  font-size: 0.8rem;
  color: var(--text-muted);
}

.reading-time {
  color: var(--text-muted);
}

/* Share buttons */
.share-buttons {
  display: flex;
  gap: 0.5rem;
}

.share-buttons button {
  background: var(--bg);
  border: 1px solid var(--border);
  padding: 0.4rem 0.6rem;
  border-radius: 6px;
  cursor: pointer;
  color: var(--text-muted);
  font-size: 0.75rem;
  display: flex;
  align-items: center;
  gap: 0.25rem;
  transition: all 0.2s;
}

.share-buttons button:hover {
  border-color: var(--accent);
  color: var(--accent);
}

.copy-btn {
  font-family: inherit;
}

/* Update notification */
.update-notification {
  position: fixed;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%);
  background: var(--surface);
  border: 1px solid var(--border);
  padding: 1rem 1.5rem;
  border-radius: 12px;
  box-shadow: 0 4px 20px var(--shadow);
  display: flex;
  align-items: center;
  gap: 1rem;
  z-index: 1000;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateX(-50%) translateY(100%); opacity: 0; }
  to { transform: translateX(-50%) translateY(0); opacity: 1; }
}

.update-notification button {
  background: var(--accent);
  color: white;
  border: none;
  padding: 0.5rem 1rem;
  border-radius: 6px;
  cursor: pointer;
  font-weight: 500;
}

.update-notification button:last-child {
  background: transparent;
  color: var(--text-muted);
  padding: 0.5rem;
}

.no-results {
  text-align: center;
  color: var(--text-muted);
  padding: 3rem;
  grid-column: 1 / -1;
}

.news-card h2 {
  font-size: 1.125rem;
  font-weight: 600;
  line-height: 1.4;
  margin-bottom: 0.75rem;
}

.news-card h2 a {
  color: inherit;
  text-decoration: none;
}

.news-card h2 a:hover {
  color: var(--accent);
}

.summary {
  color: var(--text-muted);
  font-size: 0.9rem;
  margin-bottom: 1rem;
}

.source {
  font-weight: 500;
}

/* Footer */
footer {
  background: var(--surface);
  border-top: 1px solid var(--border);
  padding: 1.5rem 0;
  text-align: center;
  color: var(--text-muted);
  font-size: 0.875rem;
}

.error {
  text-align: center;
  color: var(--industry);
  padding: 3rem;
}

/* Responsive - Large Desktop */
@media (min-width: 1400px) {
  .container {
    max-width: 1400px;
  }

  .news-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

/* Responsive - Desktop */
@media (max-width: 1200px) {
  .news-grid {
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.25rem;
  }
}

/* Responsive - Tablet */
@media (max-width: 992px) {
  .container {
    padding: 0 1.25rem;
  }

  header {
    padding: 1.5rem 0;
  }

  header h1 {
    font-size: 1.75rem;
  }

  .tagline {
    font-size: 0.875rem;
  }

  .news-grid {
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .news-card {
    padding: 1.25rem;
  }

  .news-card h2 {
    font-size: 1.05rem;
  }
}

/* Responsive - Small Tablet / Large Mobile */
@media (max-width: 768px) {
  .container {
    padding: 0 1rem;
  }

  header {
    padding: 1.25rem 0;
  }

  .header-content {
    gap: 1rem;
  }

  header h1 {
    font-size: 1.5rem;
  }

  .tagline {
    font-size: 0.8rem;
  }

  .theme-toggle {
    width: 40px;
    height: 40px;
  }

  .search-bar {
    margin-top: 0.75rem;
  }

  #searchInput {
    padding: 0.75rem 1rem 0.75rem 2.75rem;
    font-size: 0.95rem;
    border-radius: 10px;
  }

  .search-icon {
    left: 0.875rem;
  }

  .meta-bar {
    flex-direction: column;
    align-items: flex-start;
    padding: 1rem 0;
    gap: 0.75rem;
  }

  .filters {
    width: 100%;
    overflow-x: auto;
    padding-bottom: 0.5rem;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .filters::-webkit-scrollbar {
    display: none;
  }

  .filter-btn {
    flex-shrink: 0;
    padding: 0.45rem 0.875rem;
    font-size: 0.8rem;
  }

  .news-grid {
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .news-card {
    padding: 1rem;
  }

  .news-card h2 {
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }

  .summary {
    font-size: 0.85rem;
    margin-bottom: 0.75rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    padding-top: 0.5rem;
    gap: 0.5rem;
  }

  .meta {
    font-size: 0.75rem;
    gap: 0.5rem;
  }

  .share-buttons {
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .share-buttons button {
    padding: 0.35rem 0.5rem;
    font-size: 0.7rem;
  }

  .category {
    font-size: 0.7rem;
    padding: 0.2rem 0.6rem;
    margin-bottom: 0.5rem;
  }

  .trending-badge {
    font-size: 0.7rem;
    padding: 0.2rem 0.6rem;
  }

  footer {
    padding: 1.25rem 0;
    font-size: 0.8rem;
  }

  .update-notification {
    bottom: 1rem;
    left: 1rem;
    right: 1rem;
    transform: none;
    padding: 0.875rem 1rem;
    flex-wrap: wrap;
    justify-content: center;
    text-align: center;
  }

  @keyframes slideUp {
    from { transform: translateY(100%); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }
}

/* Responsive - Mobile */
@media (max-width: 480px) {
  .container {
    padding: 0 0.75rem;
  }

  header {
    padding: 1rem 0;
  }

  .header-content {
    gap: 0.75rem;
  }

  header h1 {
    font-size: 1.25rem;
  }

  .tagline {
    font-size: 0.75rem;
    margin-top: 0.15rem;
  }

  .theme-toggle {
    width: 36px;
    height: 36px;
  }

  .theme-toggle svg {
    width: 16px;
    height: 16px;
  }

  #searchInput {
    padding: 0.65rem 0.875rem 0.65rem 2.5rem;
    font-size: 0.9rem;
  }

  .search-icon {
    left: 0.75rem;
    width: 16px;
    height: 16px;
  }

  .last-updated {
    font-size: 0.75rem;
  }

  .filter-btn {
    padding: 0.4rem 0.75rem;
    font-size: 0.75rem;
  }

  .news-card {
    padding: 0.875rem;
    border-radius: 10px;
  }

  .news-card h2 {
    font-size: 0.95rem;
    line-height: 1.35;
  }

  .summary {
    font-size: 0.8rem;
    -webkit-line-clamp: 2;
  }

  .card-header {
    margin-bottom: 0.5rem;
  }

  .bookmark-btn {
    padding: 0.35rem;
  }

  .bookmark-btn svg {
    width: 16px;
    height: 16px;
  }

  .meta {
    font-size: 0.7rem;
  }

  .share-buttons button {
    padding: 0.3rem 0.45rem;
    font-size: 0.65rem;
    border-radius: 4px;
  }

  .no-results {
    padding: 2rem;
    font-size: 0.9rem;
  }

  .update-notification {
    bottom: 0.75rem;
    left: 0.75rem;
    right: 0.75rem;
    padding: 0.75rem;
    border-radius: 10px;
    gap: 0.75rem;
  }

  .update-notification button {
    padding: 0.4rem 0.75rem;
    font-size: 0.85rem;
  }
}

/* Small Mobile */
@media (max-width: 360px) {
  header h1 {
    font-size: 1.1rem;
  }

  .tagline {
    font-size: 0.7rem;
  }

  .filter-btn {
    padding: 0.35rem 0.6rem;
    font-size: 0.7rem;
  }

  .news-card h2 {
    font-size: 0.9rem;
  }

  .share-buttons {
    justify-content: space-between;
  }

  .share-buttons button {
    flex: 1;
    justify-content: center;
    min-width: 0;
  }
}

/* Touch device optimizations */
@media (hover: none) and (pointer: coarse) {
  .news-card:hover {
    transform: none;
    box-shadow: none;
  }

  .news-card:active {
    transform: scale(0.99);
  }

  .filter-btn:hover {
    border-color: var(--border);
    color: inherit;
  }

  .filter-btn:active {
    background: var(--bg);
  }

  .filter-btn.active:hover,
  .filter-btn.active:active {
    background: var(--text);
    color: var(--bg);
    border-color: var(--text);
  }

  .share-buttons button:hover {
    border-color: var(--border);
    color: var(--text-muted);
  }

  .share-buttons button:active {
    background: var(--border);
  }

  .bookmark-btn:hover {
    background: transparent;
    color: var(--text-muted);
  }

  .bookmark-btn:active {
    background: var(--bg);
  }

  .theme-toggle:hover {
    border-color: var(--border);
    color: var(--text);
  }

  .theme-toggle:active {
    background: var(--bg);
  }
}

/* Landscape orientation on mobile */
@media (max-height: 500px) and (orientation: landscape) {
  header {
    padding: 0.75rem 0;
  }

  .meta-bar {
    padding: 0.75rem 0;
  }

  .news-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .update-notification {
    bottom: 0.5rem;
    padding: 0.5rem 0.75rem;
  }
}

/* High resolution displays */
@media (-webkit-min-device-pixel-ratio: 2), (min-resolution: 192dpi) {
  .news-card {
    border-width: 0.5px;
  }
}

/* Reduced motion preference */
@media (prefers-reduced-motion: reduce) {
  .news-card,
  .filter-btn,
  .theme-toggle,
  .bookmark-btn,
  .share-buttons button,
  #searchInput {
    transition: none;
  }

  .trending-badge {
    animation: none;
  }

  .update-notification {
    animation: none;
  }
}

/* Print styles */
@media print {
  header,
  footer,
  .search-bar,
  .filters,
  .meta-bar,
  .share-buttons,
  .bookmark-btn,
  .theme-toggle,
  .update-notification {
    display: none !important;
  }

  .news-grid {
    display: block;
  }

  .news-card {
    break-inside: avoid;
    page-break-inside: avoid;
    margin-bottom: 1rem;
    border: 1px solid #ccc;
    box-shadow: none;
  }

  .news-card h2 a {
    text-decoration: underline;
  }

  .summary {
    display: block;
    -webkit-line-clamp: unset;
  }
}
</style>
