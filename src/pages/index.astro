---
import Layout from '../layouts/Layout.astro';
import NewsCard from '../components/NewsCard.astro';
import fs from 'fs';
import path from 'path';

// Read news data at build time
const newsDataPath = path.join(process.cwd(), 'news-data.json');
let newsData = { lastUpdated: new Date().toISOString(), articles: [] };

try {
  const rawData = fs.readFileSync(newsDataPath, 'utf-8');
  newsData = JSON.parse(rawData);
} catch (e) {
  console.error('Could not read news data:', e);
}

const { lastUpdated, articles } = newsData;
const formattedDate = new Date(lastUpdated).toLocaleDateString('en-US', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  hour: '2-digit',
  minute: '2-digit'
});

// Map articles for proper link field
const mappedArticles = articles.map((a: any) => ({
  ...a,
  link: a.url || a.link
}));
---

<Layout title="Tech Plus By Ramzi - AI, Dev Tools & Tech News">
  <header>
    <div class="container">
      <div class="header-content">
        <div>
          <h1>Tech Plus By Ramzi</h1>
          <p class="tagline">AI, Developer Tools & Tech Industry News</p>
        </div>
        <button class="theme-toggle" id="themeToggle" title="Toggle theme">
          <svg class="icon-sun" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="5"></circle>
            <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"></path>
          </svg>
          <svg class="icon-moon" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
          </svg>
        </button>
      </div>
      <div class="search-bar">
        <svg class="search-icon" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="M21 21l-4.35-4.35"></path>
        </svg>
        <input type="text" id="searchInput" placeholder="Search articles...">
      </div>
    </div>
  </header>

  <main class="container">
    <div class="meta-bar">
      <span class="last-updated">Updated: {formattedDate}</span>
      <div class="filters">
        <button class="filter-btn active" data-filter="latest">
          <span class="filter-text">Latest</span>
          <span class="filter-badge daily">24h</span>
        </button>
        <button class="filter-btn" data-filter="AI">AI</button>
        <button class="filter-btn" data-filter="Developer Tools">Dev Tools</button>
        <button class="filter-btn" data-filter="Web Development">Web Dev</button>
        <button class="filter-btn" data-filter="Tips and Tricks">Tips & Tricks</button>
        <button class="filter-btn" data-filter="Tech Industry">Industry</button>
        <button class="filter-btn bookmark-filter" data-filter="bookmarked">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path>
          </svg>
          Saved
        </button>
      </div>
    </div>

    <div class="news-grid" id="newsGrid">
      {mappedArticles.map((article: any) => (
        <NewsCard article={article} />
      ))}
    </div>

    <div class="pagination" id="pagination">
      <div class="pagination-container">
        <button class="pagination-btn prev-btn" id="prevPage" disabled>
          <span class="btn-arrow"></span>
          <span class="btn-text">Previous</span>
        </button>
        <div class="page-numbers" id="pageNumbers">
          <!-- Page numbers will be generated by JS -->
        </div>
        <button class="pagination-btn next-btn" id="nextPage">
          <span class="btn-text">Next</span>
          <span class="btn-arrow"></span>
        </button>
      </div>
      <div class="pagination-info">
        <span id="articleCount" class="article-count"></span>
      </div>
    </div>
  </main>

  <footer>
    <div class="container">
      <p>Tech Plus By Ramzi • Auto-updated daily at 4 AM UTC</p>
    </div>
  </footer>
</Layout>

<script>
  // State
  let bookmarks: string[] = JSON.parse(localStorage.getItem('bookmarks') || '[]');
  let currentFilter = 'latest';
  let searchQuery = '';

  // Pagination state
  const ARTICLES_PER_PAGE = 10;
  let currentPage = 1;
  let filteredCards: HTMLElement[] = [];

  // DOM Elements
  const themeToggle = document.getElementById('themeToggle');
  const searchInput = document.getElementById('searchInput') as HTMLInputElement;
  const newsGrid = document.getElementById('newsGrid');
  const filterBtns = document.querySelectorAll('.filter-btn');
  const prevPageBtn = document.getElementById('prevPage') as HTMLButtonElement;
  const nextPageBtn = document.getElementById('nextPage') as HTMLButtonElement;
  const pageNumbers = document.getElementById('pageNumbers');
  const articleCount = document.getElementById('articleCount');
  const pagination = document.getElementById('pagination');

  // Initialize bookmarks UI
  function updateBookmarksUI() {
    document.querySelectorAll('.bookmark-btn').forEach(btn => {
      const link = btn.getAttribute('data-link');
      if (link && bookmarks.includes(link)) {
        btn.classList.add('bookmarked');
      } else {
        btn.classList.remove('bookmarked');
      }
    });
  }

  // Filter and search
  function filterNews() {
    const cards = document.querySelectorAll('.news-card') as NodeListOf<HTMLElement>;
    filteredCards = [];

    // Get today's date for "Latest" filter (last 24 hours)
    const now = new Date();
    const oneDayAgo = new Date(now.getTime() - 24 * 60 * 60 * 1000);

    cards.forEach(card => {
      const category = card.getAttribute('data-category') || '';
      const link = card.getAttribute('data-link') || '';
      const articleDate = new Date(card.getAttribute('data-date') || '');
      const title = card.querySelector('h2')?.textContent?.toLowerCase() || '';
      const summary = card.querySelector('.summary')?.textContent?.toLowerCase() || '';
      const source = card.querySelector('.source')?.textContent?.toLowerCase() || '';

      // Latest: show articles from last 24 hours
      // Categories: show all articles (weekly accumulated)
      // Bookmarked: show bookmarked articles
      let matchesFilter = false;
      if (currentFilter === 'latest') {
        matchesFilter = articleDate >= oneDayAgo;
      } else if (currentFilter === 'bookmarked') {
        matchesFilter = bookmarks.includes(link);
      } else {
        matchesFilter = category === currentFilter;
      }

      const matchesSearch = searchQuery === '' ||
        title.includes(searchQuery) ||
        summary.includes(searchQuery) ||
        source.includes(searchQuery);

      if (matchesFilter && matchesSearch) {
        filteredCards.push(card);
      }
      card.style.display = 'none';
    });

    // Show no results message
    const existingNoResults = document.querySelector('.no-results');
    if (existingNoResults) existingNoResults.remove();

    if (filteredCards.length === 0 && newsGrid) {
      const noResults = document.createElement('div');
      noResults.className = 'no-results';
      if (currentFilter === 'bookmarked') {
        noResults.textContent = 'No bookmarked articles yet';
      } else if (currentFilter === 'latest') {
        noResults.textContent = 'No articles from the last 24 hours';
      } else {
        noResults.textContent = 'No articles found in this category';
      }
      newsGrid.appendChild(noResults);
    }

    // Apply pagination
    updatePagination();
  }

  // Pagination logic
  function updatePagination() {
    const totalPages = Math.ceil(filteredCards.length / ARTICLES_PER_PAGE);

    // Ensure current page is valid
    if (currentPage > totalPages) currentPage = Math.max(1, totalPages);

    // Calculate start and end indices
    const startIndex = (currentPage - 1) * ARTICLES_PER_PAGE;
    const endIndex = Math.min(startIndex + ARTICLES_PER_PAGE, filteredCards.length);

    // Show only current page articles
    filteredCards.forEach((card, index) => {
      if (index >= startIndex && index < endIndex) {
        card.style.display = '';
      } else {
        card.style.display = 'none';
      }
    });

    // Generate page numbers
    if (pageNumbers) {
      pageNumbers.innerHTML = '';
      const pages = generatePageNumbers(currentPage, totalPages);

      pages.forEach((page) => {
        const btn = document.createElement('button');
        btn.className = 'page-number';

        if (page === '...') {
          btn.classList.add('ellipsis');
          btn.textContent = '…';
          btn.disabled = true;
        } else {
          btn.textContent = String(page);
          if (page === currentPage) {
            btn.classList.add('active');
          }
          btn.addEventListener('click', () => {
            currentPage = page as number;
            updatePagination();
            window.scrollTo({ top: 0, behavior: 'smooth' });
          });
        }
        pageNumbers.appendChild(btn);
      });
    }

    // Update article count
    if (articleCount) {
      articleCount.textContent = `${filteredCards.length} article${filteredCards.length !== 1 ? 's' : ''}`;
    }

    // Update button states
    if (prevPageBtn) {
      prevPageBtn.disabled = currentPage <= 1;
    }
    if (nextPageBtn) {
      nextPageBtn.disabled = currentPage >= totalPages;
    }

    // Hide pagination if only one page
    if (pagination) {
      pagination.style.display = totalPages <= 1 ? 'none' : 'flex';
    }
  }

  // Generate page numbers with ellipsis
  function generatePageNumbers(current: number, total: number): (number | string)[] {
    if (total <= 7) {
      return Array.from({ length: total }, (_, i) => i + 1);
    }

    const pages: (number | string)[] = [];

    // Always show first page
    pages.push(1);

    if (current > 3) {
      pages.push('...');
    }

    // Show pages around current
    const start = Math.max(2, current - 1);
    const end = Math.min(total - 1, current + 1);

    for (let i = start; i <= end; i++) {
      if (!pages.includes(i)) {
        pages.push(i);
      }
    }

    if (current < total - 2) {
      pages.push('...');
    }

    // Always show last page
    if (!pages.includes(total)) {
      pages.push(total);
    }

    return pages;
  }

  // Pagination event listeners
  prevPageBtn?.addEventListener('click', () => {
    if (currentPage > 1) {
      currentPage--;
      updatePagination();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  });

  nextPageBtn?.addEventListener('click', () => {
    const totalPages = Math.ceil(filteredCards.length / ARTICLES_PER_PAGE);
    if (currentPage < totalPages) {
      currentPage++;
      updatePagination();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  });

  // Theme toggle
  themeToggle?.addEventListener('click', () => {
    const html = document.documentElement;
    const current = html.getAttribute('data-theme');
    const next = current === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
  });

  // Search
  searchInput?.addEventListener('input', (e) => {
    searchQuery = (e.target as HTMLInputElement).value.toLowerCase();
    currentPage = 1; // Reset to first page on search
    filterNews();
  });

  // Filter buttons
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentFilter = btn.getAttribute('data-filter') || 'all';
      currentPage = 1; // Reset to first page on filter change
      filterNews();
    });
  });

  // Bookmark buttons
  document.querySelectorAll('.bookmark-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const link = btn.getAttribute('data-link');
      if (!link) return;

      if (bookmarks.includes(link)) {
        bookmarks = bookmarks.filter(b => b !== link);
        btn.classList.remove('bookmarked');
      } else {
        bookmarks.push(link);
        btn.classList.add('bookmarked');
      }
      localStorage.setItem('bookmarks', JSON.stringify(bookmarks));

      if (currentFilter === 'bookmarked') {
        filterNews();
      }
    });
  });

  // Share buttons
  document.querySelectorAll('.twitter-share').forEach(btn => {
    btn.addEventListener('click', () => {
      const url = btn.getAttribute('data-url');
      const title = btn.getAttribute('data-title');
      window.open(`https://twitter.com/intent/tweet?url=${encodeURIComponent(url || '')}&text=${encodeURIComponent(title || '')}`, '_blank');
    });
  });

  document.querySelectorAll('.linkedin-share').forEach(btn => {
    btn.addEventListener('click', () => {
      const url = btn.getAttribute('data-url');
      window.open(`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url || '')}`, '_blank');
    });
  });

  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const url = btn.getAttribute('data-url');
      if (url) {
        await navigator.clipboard.writeText(url);
        const original = btn.textContent;
        btn.textContent = '✓ Copied!';
        setTimeout(() => btn.textContent = original, 2000);
      }
    });
  });

  // Initialize
  updateBookmarksUI();
  filterNews(); // Initialize pagination
</script>
