---
interface Props {
  article: {
    title: string;
    link: string;
    source: string;
    date: string;
    category: string;
    summary: string;
    readingTime?: number;
    trendingScore?: number;
  };
}

const { article } = Astro.props;
const categoryClass = article.category.toLowerCase().replace(/\s+/g, '-');
const isTrending = (article.trendingScore || 0) > 70;
const formattedDate = new Date(article.date).toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  hour: '2-digit',
  minute: '2-digit'
});
---

<article class={`news-card ${isTrending ? 'trending' : ''}`} data-category={article.category} data-link={article.link} data-date={article.date}>
  <div class="card-header">
    <div class="card-badges">
      <span class={`category ${categoryClass}`}>{article.category}</span>
      {isTrending && <span class="trending-badge">🔥 Trending</span>}
    </div>
    <button class="bookmark-btn" title="Bookmark" data-link={article.link}>
      <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path>
      </svg>
    </button>
  </div>

  <h2><a href={article.link} target="_blank" rel="noopener">{article.title}</a></h2>

  {article.summary && <p class="summary">{article.summary}</p>}

  <div class="card-footer">
    <div class="meta">
      <span class="source">{article.source}</span>
      <span>{formattedDate}</span>
      {article.readingTime && <span class="reading-time">📖 {article.readingTime} min read</span>}
    </div>
    <div class="share-buttons">
      <button class="twitter-share" data-url={article.link} data-title={article.title} title="Share on Twitter">
        𝕏 Tweet
      </button>
      <button class="linkedin-share" data-url={article.link} data-title={article.title} title="Share on LinkedIn">
        in Share
      </button>
      <button class="copy-btn" data-url={article.link} title="Copy link">
        📋 Copy
      </button>
    </div>
  </div>
</article>
